# NetShield backend configuration. Copy to .env and fill in.

# Path to Wireshark's tshark.exe (optional; this is the default)
# TSHARK_PATH=C:\Program Files\Wireshark\tshark.exe

# Telus/Arcadyan router integration (optional).
# Leave ROUTER_USER/ROUTER_PASS blank to disable the router collector.
ROUTER_URL=http://192.168.1.254
ROUTER_USER=
ROUTER_PASS=
# How often to poll the router for the device list, in ms (default 5 min).
ROUTER_POLL_MS=300000

# IP reputation APIs (optional). Used only when "Enable optional online
# reputation APIs" is checked in the dashboard settings. Provide either or
# both keys; leave blank to skip that source.
# AbuseIPDB (free tier: 1,000 checks/day): https://www.abuseipdb.com/account/api
ABUSEIPDB_API_KEY=
# VirusTotal (free tier: 4 requests/min): https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=
